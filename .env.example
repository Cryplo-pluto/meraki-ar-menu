# ============================================================
# Meraki AR Menu — environment variables
# Copy this file to `.env` and fill in the real values.
# NEVER commit `.env` (it is gitignored). Transfer it between
# machines privately (USB / password manager), not via git.
# ============================================================

# --- Required to run the site (server + browser) ---
# Found in: Supabase Dashboard -> Project Settings -> API
# Project: meraki-cafe (ref lbmrywnejlrmmcnehnya, org "Yange")
SUPABASE_PROJECT_ID="lbmrywnejlrmmcnehnya"
SUPABASE_URL="https://lbmrywnejlrmmcnehnya.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Same values again for the browser bundle (Vite only exposes VITE_* vars)
VITE_SUPABASE_PROJECT_ID="lbmrywnejlrmmcnehnya"
VITE_SUPABASE_URL="https://lbmrywnejlrmmcnehnya.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# --- Optional: admin features (GLB model upload/normalisation) ---
# Found in: Supabase Dashboard -> Project Settings -> API keys (secret)
# Keep this one especially safe — it bypasses all row security.
# SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# --- Optional: only needed to run database migrations from this machine ---
# Token: created at https://supabase.com/dashboard/account/tokens
# DB password: set when the project was created (reset via Dashboard ->
# Project Settings -> Database if lost).
# SUPABASE_ACCESS_TOKEN="sbp_..."
# SUPABASE_DB_PASSWORD="..."
